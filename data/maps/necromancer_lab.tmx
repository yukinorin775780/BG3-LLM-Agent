 <!--
   necromancer_lab.tmx - 死灵法师废弃实验室 (25x25)

   动线设计: A (门厅) → B (走廊) → [可选 C (书房)] → D (手术室) → 出口

   区域布局:
   - Area A (y=15-22): 门厅，玩家出生点 P(x=4, y=18)
   - Area B (y=9-11): 必经走廊，酸液+毒气陷阱
   - Area C (x=21-22, y=9-11): 可选书房，日记+宝箱
   - Area D (y=1-5): 主手术室，Gribbo+掩体+出口门

   通道口 (collision层中 x=通道位置):
   - A→B: Row 14, x=12
   - B→D: Row 06, x=12
   - B↔C: Row 08-12, x=20-21 (宽度2格)
   - 出口门: Row 00, x=12-14

   collision层: 1=墙, 0=可通行
 -->
 <tileset firstgid="1" name="dungeon_tiles" tilewidth="16" tileheight="16" tilecount="100" columns="10">
  <image source="../web_ui/assets/2D Pixel Dungeon Asset Pack/character and tileset/Dungeon_Tileset.png" width="160" height="160"/>
 </tileset>

